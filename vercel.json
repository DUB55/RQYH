{
  "version": 2,
  "name": "ruqiyah-kinderen",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static",
      "config": {
        "distDir": ""
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "status": 200
    },
    {
      "src": "/Designer (19)_transparent.png",
      "dest": "/Designer (19)_transparent.png"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
